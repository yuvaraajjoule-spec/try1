# ============================================================
# dYdX v4 Credentials
# ============================================================
# Option A (Recommended): Private key + wallet address
# Your dYdX wallet private key (hex string, with or without 0x prefix)
DYDX_PRIVATE_KEY=

# Your dYdX wallet address (starts with dydx1...)
DYDX_WALLET_ADDRESS=

# Option B: 24-word mnemonic (fallback if private key not set)
# DYDX_MNEMONIC="word1 word2 ... word24"

# Network: "mainnet" or "testnet"
DYDX_NETWORK=mainnet

# ============================================================
# Telegram Bot Control
# ============================================================
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
TELEGRAM_CHAT_ID=123456789

# ============================================================
# Trading Parameters
# ============================================================
TRADE_SYMBOL=BTC-USD
CANDLE_RESOLUTION=1MIN
POLL_INTERVAL_SECONDS=60

# ============================================================
# Position Sizing & Leverage
# ============================================================
# Fraction of equity per trade (0.10 = 10%)
POSITION_SIZE_PCT=0.10
LEVERAGE=3

# ============================================================
# Risk Management
# ============================================================
# Emergency stop loss (0.015 = 1.5%)
STOP_LOSS_PCT=0.015
TAKE_PROFIT_PCT=0.03
MAX_DAILY_LOSS_USDC=100

# ============================================================
# 🐉 Hydra Engine Parameters
# ============================================================
# The bot uses 7 independent indicators that each cast a weighted vote.
# A trade triggers when the aggregate score crosses the threshold.
#
# INDICATORS:
#   1. EMA Ribbon (8/13/21/55) — trend alignment    (20% weight)
#   2. RSI + Divergence        — momentum            (15% weight)
#   3. VWAP Bands              — fair value           (15% weight)
#   4. Bollinger Squeeze       — volatility breakout  (15% weight)
#   5. Keltner Channel         — breakout confirm     (10% weight)
#   6. Volume Profile (RVOL)   — volume confirm       (15% weight)
#   7. ATR Regime Filter       — dead/normal/volatile (10% weight)
#
# EXIT LAYERS:
#   - Trailing stop (ATR-based, tightens with profit)
#   - Partial TP at 1× ATR profit
#   - Score reversal (opposite signal)
#   - Time-based (max hold candles)
#   - Emergency SL (hard %)

# Min score to trigger a trade (20–95). Higher = fewer but stronger signals.
SIGNAL_THRESHOLD=60

# Trailing stop ATR multiplier (0.5–5.0). Lower = tighter stop.
TRAILING_ATR_MULT=1.5

# Max candles to hold a position before time-based exit (3–120).
MAX_HOLD_CANDLES=15

# Fraction of position to close at first TP (0.1–0.9). 0.5 = close 50%.
PARTIAL_TP_PCT=0.5

# Candles to skip after a losing trade (0–20). Prevents revenge trading.
COOLDOWN_CANDLES=2

# Fastest EMA in the ribbon (3–20).
EMA_FAST=8

# RSI calculation period (3–21).
RSI_PERIOD=7

# Bollinger Band period (10–50).
BB_PERIOD=20

# Auto-adjust threshold based on recent win rate (true/false).
ADAPTIVE_THRESHOLD=true

# ============================================================
# Dry Run Mode
# ============================================================
DRY_RUN=true
DRY_RUN_EQUITY=1000.0

# ============================================================
# Render + UptimeRobot (Keep-Alive)
# ============================================================
# PORT=8080
