# ============================================================
# dYdX v4 Credentials
# ============================================================
# Option A (Recommended): Private key + wallet address
# Your dYdX wallet private key (hex string, with or without 0x prefix)
DYDX_PRIVATE_KEY=

# Your dYdX wallet address (starts with dydx1...)
DYDX_WALLET_ADDRESS=

# Option B: 24-word mnemonic (fallback if private key not set)
# DYDX_MNEMONIC="word1 word2 ... word24"

# Network: "mainnet" or "testnet"
# Can be changed live via Telegram: /set network testnet
DYDX_NETWORK=mainnet

# ============================================================
# Telegram Bot Control
# ============================================================
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# Your personal Telegram chat ID (find it via @userinfobot)
# Only this chat ID can control the bot — leave blank for no restriction
TELEGRAM_CHAT_ID=123456789

# ============================================================
# Trading Parameters
# ============================================================
# Market symbol to trade
TRADE_SYMBOL=BTC-USD

# Candle resolution: 1MIN, 5MINS, 15MINS, 30MINS, 1HOUR, 4HOURS, 1DAY
# Can be changed live via Telegram: /set candle_resolution 5MINS
CANDLE_RESOLUTION=15MINS

# How many candles to fetch for SMC analysis
CANDLE_LIMIT=100

# How often the bot checks for signals (seconds)
# Can be changed live via Telegram: /set poll_interval 30
POLL_INTERVAL_SECONDS=60

# ============================================================
# Position Sizing & Leverage
# ============================================================
# USDC collateral to use per trade
# Can be changed live via Telegram: /set position_size_usdc 100
POSITION_SIZE_USDC=50

# Leverage multiplier (1–20)
# Can be changed live via Telegram: /set leverage 5
LEVERAGE=1

# ============================================================
# Risk Management
# ============================================================
# Stop loss as a fraction (0.015 = 1.5%)
# Can be changed live via Telegram: /set stop_loss_pct 0.02
STOP_LOSS_PCT=0.015

# Take profit as a fraction (0.03 = 3%)
# Can be changed live via Telegram: /set take_profit_pct 0.04
TAKE_PROFIT_PCT=0.03

# Maximum total loss allowed per calendar day (USDC)
# Can be changed live via Telegram: /set max_daily_loss_usdc 200
MAX_DAILY_LOSS_USDC=100

# ============================================================
# Dry Run Mode
# ============================================================
# "true" = log orders without placing them (SAFE for testing)
# Can be toggled live via Telegram: /dryrun
DRY_RUN=true

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# Render + UptimeRobot (Keep-Alive)
# ============================================================
# Render automatically injects PORT — do NOT hard-code this in .env
# Leave blank locally; the bot defaults to 8080.
# PORT=8080
#
# UptimeRobot monitor URL (for reference only — not read by code):
#   https://YOUR-RENDER-APP.onrender.com/health
