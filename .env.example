# ============================================================
# dYdX v4 Credentials
# ============================================================
# Your 24-word mnemonic phrase from dYdX / dYdX Chain wallet
# Keep this PRIVATE — never share or commit it
DYDX_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24"

# Network: "mainnet" or "testnet"
DYDX_NETWORK=mainnet

# ============================================================
# Trading Parameters
# ============================================================
# Market symbol to trade
TRADE_SYMBOL=BTC-USD

# Candle resolution: 1MIN, 5MINS, 15MINS, 30MINS, 1HOUR, 4HOURS, 1DAY
CANDLE_RESOLUTION=15MINS

# How many candles to fetch for SMC analysis
CANDLE_LIMIT=100

# How often the bot checks for signals (seconds)
POLL_INTERVAL_SECONDS=60

# ============================================================
# Position Sizing & Leverage
# ============================================================
# USDC collateral to use per trade
POSITION_SIZE_USDC=50

# Leverage multiplier (1 = no leverage, max depends on dYdX market)
LEVERAGE=1

# ============================================================
# Risk Management
# ============================================================
# Stop loss as a fraction (0.015 = 1.5%)
STOP_LOSS_PCT=0.015

# Take profit as a fraction (0.03 = 3%)
TAKE_PROFIT_PCT=0.03

# Maximum total loss allowed per calendar day (USDC)
MAX_DAILY_LOSS_USDC=100

# ============================================================
# Dry Run Mode
# ============================================================
# Set to "true" to log orders without actually placing them
DRY_RUN=false

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
