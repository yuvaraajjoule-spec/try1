# ============================================================
# dYdX v4 Credentials
# ============================================================
# Option A (Recommended): Private key + wallet address
# Your dYdX wallet private key (hex string, with or without 0x prefix)
DYDX_PRIVATE_KEY=

# Your dYdX wallet address (starts with dydx1...)
DYDX_WALLET_ADDRESS=

# Option B: 24-word mnemonic (fallback if private key not set)
# DYDX_MNEMONIC="word1 word2 ... word24"

# Network: "mainnet" or "testnet"
# Can be changed live via Telegram: /set network testnet
DYDX_NETWORK=mainnet

# ============================================================
# Telegram Bot Control
# ============================================================
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# Your personal Telegram chat ID (find it via @userinfobot)
# Only this chat ID can control the bot — leave blank for no restriction
TELEGRAM_CHAT_ID=123456789

# ============================================================
# Trading Parameters
# ============================================================
# Market symbol to trade
TRADE_SYMBOL=BTC-USD

# Candle resolution: 1MIN, 5MINS, 15MINS, 30MINS, 1HOUR, 4HOURS, 1DAY
# Can be changed live via Telegram: /set candle_resolution 5MINS
CANDLE_RESOLUTION=1MIN

# How often the bot checks for signals (seconds)
# Can be changed live via Telegram: /set poll_interval 30
POLL_INTERVAL_SECONDS=60

# ============================================================
# Position Sizing & Leverage
# ============================================================
# Fraction of live account equity to use as collateral per trade.
# e.g. 0.10 = 10% of equity per trade (auto-scales with account).
# Can be changed live via Telegram: /set position_size_pct 10
POSITION_SIZE_PCT=0.10

# Leverage multiplier (1–20).
# Scales contract size ONLY — does NOT move your SL/TP price levels.
# Can be changed live via Telegram: /set leverage 5
LEVERAGE=3

# ============================================================
# Risk Management
# ============================================================
# Emergency stop loss as a fraction (0.015 = 1.5%)
# This is a SAFETY NET only — normal exits are CHOCH-based (structure reversal).
# Can be changed live via Telegram.
STOP_LOSS_PCT=0.015

# Take profit (LEGACY — no longer used for exits)
# Exits are now driven by CHOCH (Change of Character) signals.
# Kept for backwards compatibility; set far away so it never triggers.
TAKE_PROFIT_PCT=0.03

# Maximum total loss allowed per calendar day (USDC)
# Bot stops trading for the day once this limit is hit.
# Can be changed live via Telegram.
MAX_DAILY_LOSS_USDC=100

# ============================================================
# SMC Strategy Parameters
# ============================================================
# The bot uses Smart Money Concepts (BOS → CHOCH) confirmed by SuperTrend.
#
# HOW IT WORKS:
#   1. Detect swing highs/lows (lookback = SWING_LENGTH bars)
#   2. Count BOS (Break of Structure) events in one direction
#   3. When BOS count >= MIN_BOS_COUNT and a CHOCH (Change of Character) fires
#   4. Confirm with SuperTrend direction
#   5. Enter trade (BUY or SELL)
#   6. Exit when opposite CHOCH fires (structure-based exit)
#
# All of these can be changed live via Telegram Settings panel.

# Minimum BOS events before a CHOCH triggers a trade signal (1–10)
# Higher = fewer but higher-conviction signals
MIN_BOS_COUNT=2

# Bars lookback for swing high/low detection (2–50)
# Lower = more sensitive (more swings), Higher = smoother (fewer swings)
SWING_LENGTH=5

# SuperTrend ATR period (1–50)
# Controls how smooth the SuperTrend line is
SUPERTREND_ATR_PERIOD=10

# SuperTrend ATR multiplier (0.5–10.0)
# Higher = wider bands = fewer but stronger signals
SUPERTREND_MULTIPLIER=3.0

# ============================================================
# Dry Run Mode
# ============================================================
# "true" = log orders without placing them (SAFE for testing)
# Can be toggled live via Telegram.
DRY_RUN=true

# Starting simulated equity for dry-run mode (USDC)
# The bot tracks simulated P&L % against this balance.
# You can see daily profit/loss % in the Telegram P&L screen.
DRY_RUN_EQUITY=1000.0

# ============================================================
# Render + UptimeRobot (Keep-Alive)
# ============================================================
# Render automatically injects PORT — do NOT hard-code this in .env
# Leave blank locally; the bot defaults to 8080.
# PORT=8080
#
# UptimeRobot monitor URL (for reference only — not read by code):
#   https://YOUR-RENDER-APP.onrender.com/health
