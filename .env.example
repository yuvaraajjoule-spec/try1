# ============================================================
# dYdX v4 Credentials
# ============================================================
# Option A (Recommended): Private key + wallet address
# Your dYdX wallet private key (hex string, with or without 0x prefix)
DYDX_PRIVATE_KEY=

# Your dYdX wallet address (starts with dydx1...)
DYDX_WALLET_ADDRESS=

# Option B: 24-word mnemonic (fallback if private key not set)
# DYDX_MNEMONIC="word1 word2 ... word24"

# Network: "mainnet" or "testnet"
DYDX_NETWORK=mainnet

# ============================================================
# Telegram Bot Control
# ============================================================
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
TELEGRAM_CHAT_ID=123456789

# ============================================================
# Trading Parameters
# ============================================================
TRADE_SYMBOL=BTC-USD
CANDLE_RESOLUTION=1MIN
POLL_INTERVAL_SECONDS=60
CANDLE_LIMIT=100

# ============================================================
# Position Sizing & Leverage
# ============================================================
# Fraction of equity per trade (0.10 = 10%)
POSITION_SIZE_PCT=0.10
LEVERAGE=3

# ============================================================
# Risk Management
# ============================================================
# Emergency stop loss percentage (0.015 = 1.5%)
# Triggered by the SL monitor if price hits this level.
STOP_LOSS_PCT=0.015
MAX_DAILY_LOSS_USDC=100

# ============================================================
# ⚡ SuperTrend Parameters (Pine Script v4 defaults)
# ============================================================
# Pure 1:1 translation of the Pine Script SuperTrend indicator.
#
#   src  = hl2 (average of high + low)
#   up   = src - (Multiplier × ATR)  → support band in uptrend
#   dn   = src + (Multiplier × ATR)  → resistance band in downtrend
#   BUY  = trend flips from -1 → +1  (bearish → bullish)
#   SELL = trend flips from +1 → -1  (bullish → bearish)
#
# Signal is confirmed after a 3-second re-check before executing.
# Signals with ATR < 0.05% of price are skipped (too small to trade).

# ATR period (Pine Script default: 10)
ST_ATR_PERIOD=10

# SuperTrend multiplier (Pine Script default: 3.0)
# Lower = more signals + tighter bands. Higher = fewer + wider.
ST_MULTIPLIER=3.0

# ============================================================
# Dry Run Mode
# ============================================================
DRY_RUN=true
DRY_RUN_EQUITY=1000.0

# ============================================================
# Render + UptimeRobot (Keep-Alive)
# ============================================================
# PORT=8080
