# ============================================================
# dYdX v4 Credentials
# ============================================================
# Option A (Recommended): Private key + wallet address
# Your dYdX wallet private key (hex string, with or without 0x prefix)
DYDX_PRIVATE_KEY=

# Your dYdX wallet address (starts with dydx1...)
DYDX_WALLET_ADDRESS=

# Option B: 24-word mnemonic (fallback if private key not set)
# DYDX_MNEMONIC="word1 word2 ... word24"

# Network: "mainnet" or "testnet"
DYDX_NETWORK=mainnet

# ============================================================
# Telegram Bot Control
# ============================================================
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
TELEGRAM_CHAT_ID=123456789

# ============================================================
# Trading Parameters
# ============================================================
TRADE_SYMBOL=BTC-USD
CANDLE_RESOLUTION=1MIN
POLL_INTERVAL_SECONDS=60

# ============================================================
# Position Sizing & Leverage
# ============================================================
# Fraction of equity per trade (0.10 = 10%)
POSITION_SIZE_PCT=0.10
LEVERAGE=3

# ============================================================
# Risk Management
# ============================================================
# Emergency stop loss (0.015 = 1.5%)
STOP_LOSS_PCT=0.015
TAKE_PROFIT_PCT=0.03
MAX_DAILY_LOSS_USDC=100

# ============================================================
# ⚡ SuperTrend Sniper Parameters
# ============================================================
# Pure SuperTrend indicator translated from Pine Script v4.
# Every trend flip = instant trade. No thresholds, no voting.
#
# CORE:
#   SuperTrend = ATR-based trend-following indicator
#   Upper Band = hl2 - (multiplier × ATR) → ratchets UP in uptrend
#   Lower Band = hl2 + (multiplier × ATR) → ratchets DOWN in downtrend
#   BUY  = trend flips from bearish to bullish
#   SELL = trend flips from bullish to bearish
#
# FEE AWARENESS:
#   dYdX has NO gas fees — only volume-based trading fees.
#   The fee filter ensures ATR > 2× round-trip fee cost.

# ATR period for SuperTrend calculation (5–50). Default: 10 (Pine Script default).
ST_ATR_PERIOD=10

# SuperTrend multiplier (0.5–10.0). Default: 3.0 (Pine Script default).
# Lower = more signals + tighter bands. Higher = fewer + wider.
ST_MULTIPLIER=3.0

# Use Wilder's smoothed ATR (true) or SMA-based ATR (false). Default: true.
ST_USE_TRUE_ATR=true

# Trailing stop ATR multiplier (0.5–5.0). Lower = tighter stop.
TRAILING_ATR_MULT=1.5

# Max candles to hold a position before time-based exit (3–500).
MAX_HOLD_CANDLES=60

# Fraction of position to close at first TP (0.1–0.9). 0.5 = close 50%.
PARTIAL_TP_PCT=0.5

# Candles to skip after a losing trade (0–20). Prevents revenge trading.
COOLDOWN_CANDLES=1

# Fee recoup filter: skip signals where ATR is too low to cover fees (true/false).
FEE_FILTER_ENABLED=true

# Estimated dYdX taker fee per side (%). Used for fee recoup filter.
ESTIMATED_FEE_PCT=0.05

# ============================================================
# Dry Run Mode
# ============================================================
DRY_RUN=true
DRY_RUN_EQUITY=1000.0

# ============================================================
# Render + UptimeRobot (Keep-Alive)
# ============================================================
# PORT=8080
